# ============================================================
# InterviewLoop — Environment Variables Template
# Copy this file to backend/.env and fill in your secrets.
# ============================================================

# ── HuggingFace token (for pyannote.audio speaker diarization) ──────────────
# Optional — the app runs without it, but speaker diarization will be disabled.
# Get your token at: https://huggingface.co/settings/tokens
# Accept the pyannote models at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_your_token_here

# ── Deepgram API key (for real-time voice transcription in browser) ──────────
# Optional — Whisper (local) is used as fallback.
# Get your key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── macOS fork-safety (set automatically by main.py, kept here for reference) ─
OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
